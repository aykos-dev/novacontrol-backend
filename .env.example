# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=wb_user
DATABASE_PASSWORD=wb_password
DATABASE_NAME=wb_analytics
# Set false in production after initial schema exists (prefer migrations over synchronize)
DATABASE_SYNC=true

# CORS: comma-separated origins, or use ADMIN_PANEL_URL alone
CORS_ORIGINS=http://localhost:5173
# Set 1 when behind nginx / load balancer (rate limit + IP)
TRUST_PROXY=0

# JWT
JWT_SECRET=a4ORLjrKx30ls15yJN3CdtzuHVO2pqay
JWT_EXPIRES_IN=7d

# WB Token Encryption: 64 hex chars (32 bytes), or any passphrase (SHA-256 → 32 bytes)
WB_TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Wildberries API HTTP logging (JSON Lines file; Authorization masked)
WB_API_LOG_ENABLED=true
WB_API_LOG_FILE=logs/wb-api.jsonl
WB_API_LOG_MAX_BODY=16384
# Short one-line logs to Nest console (verbose; off by default)
WB_API_LOG_TO_CONSOLE=false

# Telegram
TELEGRAM_BOT_TOKEN=8626440231:AAE6mEOGLTh5UDNnMhNQuJMC0CMYRWr-4Jc
TELEGRAM_GROUP_ID=-5043988918

# Shared secret for the Telegraf process → GET /api/internal/bot/*
BOT_API_SECRET=W4c9TJH5LdhKvAWwU1dqMjUDpPalnwN0

# Admin Panel URL (HTTPS in production — required for Telegram Mini App / WebApp button)
ADMIN_PANEL_URL=http://localhost:5173

# Sync schedules (cron expressions)
SYNC_CRON_SCHEDULE=*/5 * * * *
DAILY_REPORT_TIME=0 22 * * *
MORNING_REPORT_TIME=0 9 * * *
# Min minutes between syncs for the same client (must be <= cron interval)
SYNC_RATE_LIMIT_MIN=5
